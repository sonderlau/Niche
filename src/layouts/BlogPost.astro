---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import AuthorLink from '../components/AuthorLink.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { url } from '../utils/paths';

type Props = CollectionEntry<'blog'>['data'] & { id?: string, headings?: { depth: number; slug: string; text: string }[], toc?: boolean };

const { title, description, pubDate, updatedDate, heroImage, authors, tags, id, headings = [], toc } = Astro.props;
const fallbackHero = id ? url(`/blog/${id}.png`) : url('/og.png');
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			html {
				scroll-padding-top: 5.5rem;
			}
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--shadow-md);
				max-width: 100%;
				height: auto;
			}
			.blog-container {
				position: relative;
				max-width: 1200px;
				margin: 0 auto;
				display: flex;
				justify-content: center;
			}
			.prose-wrapper {
				position: relative;
				width: 760px;
				max-width: 100%;
			}
			.prose {
				width: 100%;
				padding: 1rem;
				color: var(--color-text-main);
			}
			.prose :global(p) {
				text-align: justify;
				hyphens: auto;
			}
			.prose :global(blockquote) {
				margin: 2.25rem 0;
				padding: 1.3rem 3.25rem;
				border-left: 4px solid var(--color-accent);
				background: var(--color-bg-offset);
				border-radius: 18px;
			}
            .title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2.2rem;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--color-text-muted);
			}
            .blog-tags {
                display: flex;
                gap: 0.5rem;
                justify-content: center;
                flex-wrap: wrap;
                margin-top: 0.75rem;
            }
            .blog-tags a {
                text-decoration: none;
                font-size: 0.85rem;
                font-weight: 600;
                color: var(--color-accent);
                background: var(--color-bg-offset);
                padding: 0.2rem 0.6rem;
                border-radius: 999px;
                border: 1px solid var(--color-border);
            }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage ? (
						<Image width={1020} height={510} src={heroImage} alt={title} />
					) : (
						<img width={1020} height={510} src={fallbackHero} alt={title} />
					)}
				</div>
				<div class="blog-container">
					<div class="prose-wrapper">
						<div class="prose">
							<div class="title">
								<div class="date">
									<FormattedDate date={pubDate} />
								</div>
								<h1>{title}</h1>
								{tags && tags.length > 0 && (
									<div class="blog-tags">
										{tags.map((tag) => (
											<a href={url(`/tags/${tag}`)}>#{tag}</a>
										))}
									</div>
								)}
								<hr />
							</div>
							{toc !== false && headings.length > 0 && (
								<TableOfContents headings={headings} mobile={false} />
							)}
							<slot />
						</div>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
