---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
import projectsData from "../data/projects.json";
import { url } from "../utils/paths";
import snarkdown from "snarkdown";

const md = (text: string) => snarkdown(text.replace(/\n (?=[-*+])/g, '\n'));

const projects = projectsData.sort((a, b) => b.year - a.year);
const cols: typeof projects[] = [[], []];
projects.forEach((p, i) => cols[i % 2].push(p));
const isExternal = (href: string) => /^https?:\/\//.test(href);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Projects | ${SITE_TITLE}`}
      description="Research Projects"
    />
    <style>
      .projects-section {
        max-width: var(--max-width);
        margin: 0 auto;
      }
      .projects-hero {
        text-align: center;
        margin-bottom: 4rem;
        padding: 2rem 0;
      }
      .projects-hero h1 {
        font-family: var(--font-serif);
        font-size: 3.2rem;
        margin: 0 0 1rem 0;
        color: var(--color-text-main);
        letter-spacing: -0.02em;
        line-height: 1.2;
      }
      .projects-hero p {
        font-size: 1.15rem;
        color: var(--color-text-muted);
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.7;
      }
      .projects-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: start;
        margin-bottom: 4rem;
      }
      .projects-col {
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }
      .project-card {
        display: flex;
        flex-direction: column;
        background-color: var(--color-bg-offset);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        overflow: hidden;
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease,
          border-color 0.3s ease;
        box-shadow:
          0 4px 6px -1px rgba(0, 0, 0, 0.05),
          0 2px 4px -1px rgba(0, 0, 0, 0.03);
      }
      .project-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-lg);
        border-color: var(--color-accent);
      }
      .project-image {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
      }
      .project-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }
      .project-card:hover .project-image img {
        transform: scale(1.05);
      }
      .project-badge {
        padding: 0.35rem 0.8rem;
        background-color: var(--color-bg-offset);
        color: var(--color-text-muted);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        line-height: 1;
        border-radius: 20px;
        border: 1px solid var(--color-border);
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
      }
      .status-dot {
        display: inline-block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .status-ongoing .status-dot {
        background-color: #f59e0b;
      }
      .status-completed .status-dot {
        background-color: #22c55e;
      }
      .status-incoming .status-dot {
        background-color: #3b82f6;
      }
      .project-content-wrapper {
        display: flex;
        flex-direction: column;
        padding: 1.75rem;
      }
      .project-header-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }
      .project-year {
        font-size: 0.75rem;
        color: var(--color-accent);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .project-card h3 {
        font-family: var(--font-serif);
        font-size: 1.4rem;
        margin: 0 0 1rem 0;
        line-height: 1.3;
        color: var(--color-text-main);
      }
      .project-card h3 a {
        color: inherit;
        text-decoration: none;
      }
      .project-description {
        color: var(--color-text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.25rem;
      }
      .project-description :global(p) {
        margin-bottom: 0.75rem;
      }
      .project-description :global(ul),
      .project-description :global(ol) {
        padding-left: 1.25rem;
        margin: 0.5rem 0;
      }
      .project-description :global(li) {
        margin-bottom: 0.15rem;
      }
      .project-description :global(strong) {
        font-weight: 700;
      }
      .project-description :global(em) {
        font-style: italic;
      }
      .project-description :global(code) {
        background-color: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: 0.1rem 0.35rem;
        font-size: 0.88em;
        font-family: var(--font-mono, ui-monospace, SFMono-Regular, monospace);
      }
      .project-description :global(a) {
        color: var(--color-accent);
      }
      .project-description :global(a:hover) {
        opacity: 0.8;
        text-decoration: underline;
      }
      .project-description :global(blockquote) {
        border-left: 3px solid var(--color-accent);
        padding-left: 0.75rem;
        margin: 0.5rem 0;
        color: var(--color-text-main);
        font-style: italic;
      }
      .project-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 1rem;
        border-top: 1px solid var(--color-border);
      }
      .read-more {
        display: inline-flex;
        align-items: center;
        font-size: 0.9rem;
        color: var(--color-accent);
        text-decoration: none;
        font-weight: 600;
        transition: gap 0.2s ease;
        gap: 0.25rem;
      }
      .read-more:hover {
        gap: 0.5rem;
      }
      .github-link {
        display: inline-flex;
        align-items: center;
        color: var(--color-text-muted);
        transition: color 0.2s ease;
      }
      .github-link:hover {
        color: var(--color-text-main);
      }
      @media (max-width: 640px) {
        .projects-hero h1 {
          font-size: 2.5rem;
        }
        .projects-grid {
          grid-template-columns: 1fr;
        }
        .project-content-wrapper {
          padding: 1.5rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="projects-section">
      <div class="projects-hero">
        <h1>Research / Application Projects</h1>
        <p>Made with love and curiosity.</p>
      </div>

      <div class="projects-grid">
        {
          projects.length > 0 ? (
            cols.map((colProjects) => (
              <div class="projects-col">
                {colProjects.map((project) => {
              const href = project.link ? (isExternal(project.link) ? project.link : url(project.link)) : '';
              const external = href ? isExternal(href) : false;

              return (
                <article class="project-card">
                  {project.heroImage && (
                    <div class="project-image">
                      <img src={url(project.heroImage)} alt={project.title} />
                    </div>
                  )}

                  <div class="project-content-wrapper">
                    <div class="project-header-row">
                      <span class="project-year">
                        {project.year > 0 ? project.year : "Classical"}
                      </span>
                      <span class={`project-badge status-${project.status.toLowerCase()}`}>
                        <span class="status-dot" />
                        {project.status}
                      </span>
                    </div>
                    <h3>
                      {href ? (
                        <a href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
                          {project.title}
                        </a>
                      ) : (
                        project.title
                      )}
                    </h3>

                    <div class="project-description" set:html={md(project.description)} />

                    {(project.link || project.github) && (
                      <div class="project-actions">
                        {project.link && (
                          <a
                            href={href}
                            target={external ? '_blank' : undefined}
                            rel={external ? 'noopener noreferrer' : undefined}
                            class="read-more"
                          >
                            Read More &rarr;
                          </a>
                        )}
                        {project.github && (
                          <a
                            href={project.github}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="github-link"
                            aria-label="GitHub"
                          >
                            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                          </a>
                        )}
                      </div>
                    )}
                  </div>
                </article>
              );
            })}
              </div>
            ))
          ) : (
            <p>
              No projects found in <code>src/data/projects.json</code>.
            </p>
          )
        }
      </div>
    </main>
    <Footer />
  </body>
</html>
