---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, AUTHOR_NAME } from "../consts";
import bibFileRaw from "../data/publications.bib?raw";

interface Author {
  first: string;
  last: string;
}

interface BibEntry {
  type: string;
  key: string;
  fields: Record<string, string>;
  authors: Author[];
  raw: string;
}

function parseBibTeX(input: string): BibEntry[] {
  const entries: BibEntry[] = [];
  const rawEntries = input.split(/@(\w+)\s*\{/g).slice(1);

  for (let i = 0; i < rawEntries.length; i += 2) {
    const type = rawEntries[i].trim();
    const body = rawEntries[i + 1];
    if (!body) continue;

    const keyMatch = body.match(/^\s*([^,]+),/);
    const key = keyMatch ? keyMatch[1].trim() : "unknown";

    const fields: Record<string, string> = { title: "Untitled", year: "0000" };

    const fieldRegex =
      /(\w+)\s*=\s*(?:\{((?:[^{}]|{[^{}]*})*)\}|"((?:[^"]|\\")*)"|(\d+))/g;

    let match;
    while ((match = fieldRegex.exec(body)) !== null) {
      const fieldKey = match[1].toLowerCase();
      const val = match[2] || match[3] || match[4] || "";
      fields[fieldKey] = val.replace(/\s+/g, " ").trim();
    }

    let authors: Author[] = [];
    if (fields.author) {
      authors = fields.author.split(/\s+and\s+/i).map((str) => {
        const parts = str.split(",");
        if (parts.length > 1) {
          return { first: parts[1].trim(), last: parts[0].trim() };
        } else {
          const names = str.trim().split(" ");
          const last = names.pop() || "";
          const first = names.join(" ");
          return { first, last };
        }
      });
    }

    entries.push({ type, key, fields, authors, raw: `@${type}{${body}` });
  }
  return entries;
}

const publications = parseBibTeX(bibFileRaw).sort((a, b) => {
  return (parseInt(b.fields.year) || 0) - (parseInt(a.fields.year) || 0);
});

const formatAuthor = (auth: Author) => {
  return auth.first ? `${auth.first} ${auth.last}` : auth.last;
};

const isAuthorMe = (name: string) => {
  if (!name || !AUTHOR_NAME) return false;
  const n = name.toLowerCase().replace(/[^a-z]/g, "");
  const me = AUTHOR_NAME.toLowerCase().replace(/[^a-z]/g, "");
  return n.includes(me) || me.includes(n);
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Publications | ${SITE_TITLE}`}
      description="Academic Publications"
    />
    <style>
      .author-me {
        text-decoration: underline;
        font-weight: 500;
        color: var(--color-text-main);
      }
      .pub-note {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        margin-top: 0.35rem;
        line-height: 1.5;
      }
      #bibtex-dialog::backdrop {
        background: rgba(0,0,0,0.4);
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Publications</h1>
      <p>Selected peer-reviewed publications.</p>

      <div class="publication-list">
        {
          publications.map((entry) => (
            <article class="publication-item">
              <span class="pub-title">
                {entry.fields.title.replace(/[{}]/g, "")}
              </span>

              <div class="pub-authors">
                {entry.authors &&
                  entry.authors.map((auth, i) => {
                    const name = formatAuthor(auth);
                    const isMe = isAuthorMe(name);
                    return (
                      <>
                        <span class={isMe ? "author-me" : ""}>
                          {name.replace(/[{}]/g, "")}
                        </span>
                        {i < entry.authors.length - 1 ? ", " : ""}
                      </>
                    );
                  })}
              </div>

              <div class="pub-venue">
                {(
                  entry.fields.journal ||
                  entry.fields.booktitle ||
                  entry.fields.publisher ||
                  entry.fields.school ||
                  "Preprint"
                ).replace(/[{}]/g, "")}
                {entry.fields.year && <span> ({entry.fields.year})</span>}
              </div>

              {entry.fields.note && (
                <div class="pub-note">
                  <strong>Note:</strong> {entry.fields.note.replace(/[{}]/g, "")}
                </div>
              )}

              <div
                class="pub-links"
                style="margin-top: 0.5rem; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;"
              >
                {entry.fields.pdf ? (
                  <a
                    href={entry.fields.pdf}
                    target="_blank"
                    class="btn-outline"
                    style="padding: 2px 6px; font-size: 0.85rem; line-height: 1.4;"
                  >
                    PDF
                  </a>
                ) : entry.fields.url ? (
                  <a
                    href={entry.fields.url}
                    target="_blank"
                    class="btn-outline"
                    style="padding: 2px 6px; font-size: 0.85rem; line-height: 1.4;"
                  >
                    URL
                  </a>
                ) : null}

                {entry.fields.github && (
                  <a
                    href={entry.fields.github}
                    target="_blank"
                    style="display: inline-flex; align-items: center; gap: 0.2rem; font-size: 0.85rem; line-height: 1.4;"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink: 0;"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    GitHub
                  </a>
                )}

                {entry.fields.arxiv && (
                  <a
                    href={entry.fields.arxiv}
                    target="_blank"
                    style="display: inline-flex; align-items: center; gap: 0.2rem; font-size: 0.85rem; line-height: 1.4;"
                  >
                    <svg width="14" height="14" viewBox="0 0 32 32" fill="currentColor" style="flex-shrink: 0;"><path d="M28.23 4.686c-2.835 3.364-5.59 6.622-8.375 9.934 2.835 3.364 5.66 6.739 8.5 10.099a.63.63 0 0 1 .126.367.69.69 0 0 1-.683.674h-5.607a.713.713 0 0 1-.435-.138c-2.173-2.896-4.354-5.785-6.552-8.663-2.119 2.665-4.254 5.32-6.378 7.982a.85.85 0 0 1-.534.281.6.6 0 0 1-.035.005H4.112a.59.59 0 0 1-.456-.21.57.57 0 0 1-.093-.49.756.756 0 0 1 .12-.233l8.134-10.477L3.633 6.083a.667.667 0 0 1-.1-.265.576.576 0 0 1 .085-.438.6.6 0 0 1 .478-.248h5.539a.636.636 0 0 1 .374.125c2.107 2.787 4.224 5.57 6.297 8.383 2.047-2.638 4.105-5.268 6.127-7.923a.79.79 0 0 1 .546-.315h.02a.614.614 0 0 1 .538.271.577.577 0 0 1 .082.443"/></svg>
                    arXiv
                  </a>
                )}

                {entry.fields.doi && (
                  <a
                    href={`https://doi.org/${entry.fields.doi}`}
                    target="_blank"
                    style="font-size: 0.85rem; line-height: 1.4;"
                  >
                    DOI
                  </a>
                )}

                <button class="bibtex-btn" data-bibtex={entry.raw} style="background: none; border: none; cursor: pointer; color: var(--color-accent); font-size: 0.85rem; line-height: 1.4; padding: 0; display: inline-flex; align-items: center; gap: 0.25rem;"><span class="bibtex-arrow" style="display: inline-block; transition: transform 0.2s;">&#9654;</span> BibTeX</button>
              </div>
            </article>
          ))
        }

        {publications.length === 0 && <p>No publications found.</p>}
      </div>
    </main>
    <Footer />

    <dialog id="bibtex-dialog" style="padding: 0; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-bg); color: var(--color-text-main); max-width: min(720px, 90vw); width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.3);">
      <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; border-bottom: 1px solid var(--color-border);">
        <span style="font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted);">BibTeX</span>
        <button id="bibtex-close" style="background: none; border: none; cursor: pointer; color: var(--color-text-muted); font-size: 1.25rem; line-height: 1; padding: 0;">&times;</button>
      </div>
      <pre id="bibtex-content" style="margin: 0; padding: 1.25rem; font-size: 0.78rem; line-height: 1.55; white-space: pre-wrap; word-break: break-word; max-height: 60vh; overflow-y: auto; overflow-x: auto; color: var(--color-text-main);"></pre>
      <div style="display: flex; justify-content: flex-end; padding: 0.75rem 1.25rem; border-top: 1px solid var(--color-border); gap: 0.5rem;">
        <button id="bibtex-copy" style="padding: 0.4rem 1rem; font-size: 0.8rem; border-radius: 6px; border: 1px solid var(--color-accent); background: var(--color-accent); color: #fff; cursor: pointer; font-weight: 500;">Copy to Clipboard</button>
      </div>
    </dialog>

    <script>
      const dialog = document.getElementById("bibtex-dialog");
      const content = document.getElementById("bibtex-content");
      const closeBtn = document.getElementById("bibtex-close");
      const copyBtn = document.getElementById("bibtex-copy");

      let currentBibTeX = "";

      document.querySelectorAll(".bibtex-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          currentBibTeX = btn.getAttribute("data-bibtex");
          content.textContent = currentBibTeX;
          copyBtn.textContent = "Copy to Clipboard";
          dialog.showModal();
        });
      });

      closeBtn.addEventListener("click", () => dialog.close());

      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
      });

      dialog.addEventListener("close", () => {
        content.textContent = "";
        currentBibTeX = "";
      });

      copyBtn.addEventListener("click", async () => {
        if (!currentBibTeX) return;
        try {
          await navigator.clipboard.writeText(currentBibTeX);
          copyBtn.textContent = "Copied!";
        } catch (err) {
          copyBtn.textContent = "Failed to copy";
          console.error(err);
        }
      });
    </script>
  </body>
</html>
